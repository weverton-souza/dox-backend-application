# Copie este arquivo para .env e preencha com seus valores reais.
# .env é gitignored — cada dev mantém o seu localmente.
#
# Pré-requisitos:
#   - IntelliJ IDEA com plugin EnvFile (https://plugins.jetbrains.com/plugin/7861-envfile)
#   - O run config .run/DoxApplicationKt.run.xml já carrega o .env automaticamente
#
# REGRA: toda env var nova consumida pelo backend precisa entrar aqui sem valor.
# Este arquivo é o contrato de variáveis do projeto.

# ===== Banco de dados =====
# Defaults sugeridos para local: host=localhost port=5432 db=dox user=dox password=dox_secret
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# ===== Segurança =====
JWT_SECRET=

# ===== IA (Anthropic) =====
ANTHROPIC_API_KEY=

# ===== Email (Resend) =====
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
# Email de resposta. Pode ficar vazio em prod ou customizar por dev.
EMAIL_REPLY_TO=

# ===== Asaas =====
# Default da base URL é o sandbox. Sobrescrever só em prod.
# ASAAS_BASE_URL=https://api.asaas.com/v3
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=

# ===== CORS =====
# Default já cobre dev local (localhost:5173 e :3000). Sobrescrever em dev/prod.
# CORS_ALLOWED_ORIGINS=https://app.doxbr.com,https://admin.doxbr.com

# ===== Comportamento ligado/desligado =====
# SWAGGER_ENABLED: true em local/dev, false em prod (default)
# HSTS_ENABLED: true em prod, false em local/dev (default)
SWAGGER_ENABLED=
HSTS_ENABLED=

# ===== Storage (S3-compatible: MinIO em dev, Cloudflare R2 em prod) =====
# Padrão de nomenclatura: <env>-dox-s3-bucket (S2S)
# Defaults para MinIO local (docker-compose): endpoint=http://localhost:9000, region=us-east-1,
# bucket=dev-dox-s3-bucket, access-key=minioadmin, secret-key=minioadmin
# Em prod (Railway + R2): endpoint=https://<accountId>.r2.cloudflarestorage.com, region=auto,
# bucket=prd-dox-s3-bucket, access-key/secret-key gerados em R2 → Manage R2 API Tokens
DOX_STORAGE_ENDPOINT=
DOX_STORAGE_REGION=
DOX_STORAGE_BUCKET=
DOX_STORAGE_ACCESS_KEY=
DOX_STORAGE_SECRET_KEY=
